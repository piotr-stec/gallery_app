extends layout

block content
  .container.mt-5
    .row.justify-content-center
      .col-md-6
        .card.shadow-sm
          .card-body
            h1.card-title.h3.mb-4= title
            
            form(method='POST')
              div.mb-3
                label.form-label(for='username') Nazwa użytkownika:
                input#username.form-control(type='text', placeholder='Wpisz swój login' name='username' required)
              
              div.mb-3
                label.form-label(for='password') Hasło:
                input#password.form-control(type='password', placeholder='Wpisz swoje hasło' name='password' autocomplete='off' required)
              
              button.btn.btn-primary.w-100(type='submit') Zaloguj się

